# ── Application ──
APP_ENV=development
LOG_LEVEL=INFO

# ── Azure OpenAI ──
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Azure Cosmos DB ──
COSMOS_DB_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_DB_KEY=<your-cosmos-key>
COSMOS_DB_DATABASE=rfp-engine

# ── Azure Blob Storage ──
BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<name>;AccountKey=<key>;EndpointSuffix=core.windows.net
BLOB_RFP_CONTAINER=rfp-uploads
BLOB_ARTIFACTS_CONTAINER=generated-artifacts

# ── Azure AI Foundry / Application Insights ──
AZURE_AI_PROJECT_CONNECTION_STRING=
