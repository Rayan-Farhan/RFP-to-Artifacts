# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure Cosmos DB
COSMOS_DB_ENDPOINT=https://your-cosmosdb.documents.azure.com:443/
COSMOS_DB_KEY=your-key-here
COSMOS_DB_DATABASE=rfp_engine

# Azure Blob Storage
BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# Azure Document Intelligence
DOC_INTELLIGENCE_ENDPOINT=https://your-docintel.cognitiveservices.azure.com/
DOC_INTELLIGENCE_KEY=your-key-here

# Azure AI Foundry (Project connection string from Foundry portal → Project Settings)
AZURE_AI_PROJECT_CONNECTION_STRING=your-connection-string-here

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO